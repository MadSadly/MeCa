# Flask
SECRET_KEY=로컬개발용-반드시-바꾸세요
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# MariaDB — 아래 중 하나 또는 DATABASE_URL 한 줄
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=meca
# DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/meca?charset=utf8mb4

# Hugging Face (요약 기능) — https://huggingface.co/settings/tokens
HF_TOKEN=
# 영어 요약 예시. 한국어 요약은 HF에서 한국어 요약 모델로 교체
HF_SUMMARIZATION_MODEL=facebook/bart-large-cnn
